# Copy to .env and fill in. The server also reads these straight from the environment.

# HTTP port
PORT=8080

# Path to the SQLite database file (created automatically)
DB_PATH=data/cv.db

# Directory for uploaded photo / resume (created automatically)
UPLOADS_DIR=data/uploads

# Admin panel password (CHANGE THIS — default is "admin" and triggers a warning)
ADMIN_PASSWORD=change-me-to-something-strong

# Telegram notifications for the contact form (optional).
# 1. Create a bot via @BotFather -> get the token.
# 2. Write to your bot once, then open
#    https://api.telegram.org/bot<token>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Spotify integration (optional): "now playing" + top tracks/artists.
# 1. Create an app at https://developer.spotify.com/dashboard.
# 2. Add SPOTIFY_REDIRECT_URI below to the app's Redirect URIs.
# 3. Connect your account once via the admin panel's Spotify tab.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://semenovm.ru/api/spotify/callback
